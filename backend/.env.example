NODE_ENV=development
PORT=4000
DATABASE_URL=file:./dev.db
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:8080
DISABLE_AUTH=false
APP_ORIGIN=http://127.0.0.1:8080
API_PUBLIC_ORIGIN=http://127.0.0.1:4000
JWT_ACCESS_SECRET=replace_me_with_local_access_secret
JWT_REFRESH_SECRET=replace_me_with_local_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:4000/auth/google/callback
AI_PROVIDER=heuristic
AI_PROVIDER_MODEL=nudgr-v1
S3_ENDPOINT=https://your-s3-endpoint
S3_REGION=auto
S3_BUCKET=nudgr-assets
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_FORCE_PATH_STYLE=false
SESSION_RECORDING_RETENTION_DAYS=7
