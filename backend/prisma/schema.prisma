generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile          Profile?
  externalAuthAccounts ExternalAuthAccount[]
  analyticsProperties AnalyticsProperty[]
  subscriptions    Subscription[]
  apiKeys          ApiKey[]
  usageRecords     UsageRecord[]
  dashboardConfigs DashboardConfig[]
  alertConfigs     AlertConfig[]
  abTests          AbTest[]
  ownedTeamMembers TeamMember[]      @relation("TeamOwnerMembers")
  memberTeams      TeamMember[]      @relation("TeamUserMembership")
  exportJobs       ExportJob[]
  analyticsEvents  AnalyticsEvent[]
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExternalAuthAccount {
  id                String    @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  email             String?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AnalyticsProperty {
  id           String    @id @default(uuid())
  userId       String
  name         String
  domain       String
  propertyType String    @default("website")
  environment  String    @default("production")
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeys            ApiKey[]
  frictionEvents     FrictionEvent[]
  performanceMetrics PerformanceMetric[]
  errorLogs          ErrorLog[]
  sessionRecordings  SessionRecording[]

  @@index([userId, createdAt])
  @@index([userId, environment])
}

model Subscription {
  id                   String           @id @default(uuid())
  userId               String
  tier                 String           @default("free")
  status               String           @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model ApiKey {
  id             String    @id @default(uuid())
  userId         String
  propertyId     String?
  keyName        String
  keyHash        String    @unique
  keyPrefix      String
  isActive       Boolean   @default(true)
  allowedDomains Json
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  property AnalyticsProperty? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([propertyId, isActive])
}

model UsageRecord {
  id          String   @id @default(uuid())
  userId      String
  usageType   String
  amount      Int
  unit        String
  periodStart DateTime
  periodEnd   DateTime
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usageType, periodStart])
}

model UsageLimit {
  id             String           @id @default(uuid())
  tier           String
  usageType      String
  includedAmount Int
  overagePrice   Decimal
  unit           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([tier, usageType])
}

model FrictionEvent {
  id            String   @id @default(uuid())
  userId        String?
  propertyId    String?
  eventType     String
  pageUrl       String
  sessionId     String
  severityScore Int      @default(0)
  metadata      Json?
  createdAt     DateTime @default(now())

  property AnalyticsProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@index([propertyId, createdAt])
}

model PerformanceMetric {
  id          String   @id @default(uuid())
  userId      String?
  propertyId  String?
  metricName  String
  metricValue Float
  pageUrl     String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  property AnalyticsProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([metricName, createdAt])
  @@index([propertyId, createdAt])
}

model ErrorLog {
  id            String   @id @default(uuid())
  userId        String?
  propertyId    String?
  errorType     String
  errorMessage  String
  errorStack    String?
  componentName String?
  pageUrl       String?
  userAgent     String?
  severity      String
  metadata      Json?
  createdAt     DateTime @default(now())

  property AnalyticsProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([severity, createdAt])
  @@index([propertyId, createdAt])
}

model RateLimit {
  id           String   @id @default(uuid())
  identifier   String
  endpoint     String
  requestCount Int      @default(1)
  windowStart  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([identifier, endpoint])
  @@index([identifier, endpoint])
  @@index([windowStart])
}

model HeatmapData {
  id               String   @id @default(uuid())
  pageUrl          String
  elementSelector  String
  interactionType  String
  xPosition        Int?
  yPosition        Int?
  viewportWidth    Int?
  viewportHeight   Int?
  interactionCount Int      @default(1)
  totalDurationMs  Int      @default(0)
  avgDurationMs    Int?
  frictionScore    Int      @default(0)
  dateBucket       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  @@unique([pageUrl, elementSelector, interactionType, dateBucket])
  @@index([pageUrl])
  @@index([dateBucket])
  @@index([interactionType])
  @@index([frictionScore])
}

model ScrollDepthAnalytics {
  id                  String   @id @default(uuid())
  pageUrl             String
  maxScrollPercentage Int
  avgScrollPercentage Int
  bounceAtPercentage  Int?
  totalSessions       Int      @default(1)
  dateBucket          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now())

  @@index([pageUrl])
  @@index([dateBucket])
}

model PagePerformanceMetric {
  id                        String   @id @default(uuid())
  pageUrl                   String
  avgLoadTimeMs             Int?
  avgTimeToInteractiveMs    Int?
  avgFirstContentfulPaintMs Int?
  totalPageViews            Int      @default(1)
  bounceRate                Decimal?
  avgTimeOnPageSeconds      Int?
  exitRate                  Decimal?
  dateBucket                DateTime @default(now())
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @default(now())

  @@index([pageUrl])
  @@index([dateBucket])
}

model FormAnalytics {
  id                  String   @id @default(uuid())
  pageUrl             String
  formSelector        String
  fieldName           String
  fieldType           String?
  totalInteractions   Int      @default(0)
  totalErrors         Int      @default(0)
  errorRate           Decimal?
  avgTimeToCompleteMs Int?
  abandonmentCount    Int      @default(0)
  abandonmentRate     Decimal?
  commonErrorMessages Json?
  dateBucket          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now())

  @@index([pageUrl])
  @@index([errorRate])
  @@index([dateBucket])
}

model DashboardConfig {
  id              String   @id @default(uuid())
  userId          String
  name            String
  description     String?
  layout          Json
  filters         Json
  isDefault       Boolean  @default(false)
  isShared        Boolean  @default(false)
  sharedWithRoles Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isDefault])
}

model AlertConfig {
  id                   String    @id @default(uuid())
  userId               String
  name                 String
  description          String?
  alertType            String
  conditions           Json
  notificationChannels Json
  isActive             Boolean   @default(true)
  lastTriggeredAt      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationLogs NotificationLog[]

  @@index([userId])
  @@index([isActive])
}

model AbTest {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  variants    Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TeamMember {
  id           String    @id @default(uuid())
  teamOwnerId  String
  memberEmail  String
  memberUserId String?
  role         String    @default("viewer")
  status       String    @default("pending")
  invitedAt    DateTime  @default(now())
  joinedAt     DateTime?

  teamOwner  User  @relation("TeamOwnerMembers", fields: [teamOwnerId], references: [id], onDelete: Cascade)
  memberUser User? @relation("TeamUserMembership", fields: [memberUserId], references: [id], onDelete: SetNull)

  @@unique([teamOwnerId, memberEmail])
  @@index([teamOwnerId])
  @@index([memberUserId])
}

model SessionRecording {
  id                  String    @id @default(uuid())
  propertyId          String?
  sessionId           String
  storagePath         String
  durationSeconds     Int?
  fileSizeBytes       BigInt?
  recordingStart      DateTime
  recordingEnd        DateTime?
  frictionEventsCount Int       @default(0)
  metadata            Json
  createdAt           DateTime  @default(now())

  property AnalyticsProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([propertyId, createdAt])
  @@index([createdAt])
}

model ExportJob {
  id           String    @id @default(uuid())
  userId       String
  exportType   String
  status       String    @default("pending")
  storagePath  String?
  parameters   Json
  errorMessage String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model NotificationLog {
  id               String    @id @default(uuid())
  alertId          String?
  notificationType String
  recipient        String
  subject          String?
  message          String
  status           String    @default("pending")
  errorMessage     String?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())

  alert AlertConfig? @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@index([alertId])
  @@index([createdAt])
}

model AnalyticsEvent {
  id              String   @id @default(uuid())
  userId          String?
  eventName       String
  eventProperties Json
  pageUrl         String?
  sessionId       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventName])
  @@index([createdAt])
}
